@prefix :      <https://padi.authority/v1/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<https://padi.authority/v1/> rdf:type owl:Ontology ;
    rdfs:label "PADI v2.0 Master Taxonomy" ;
    rdfs:comment "Official OWL 2 Logic for Practice-Area Depth Index (PADI) with Temporal Velocity tracking." .

#################################################################
#    1. Core Properties & Metrics
#################################################################

:lastValidated a owl:DatatypeProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range xsd:dateTime ;
    rdfs:label "Last Validation Timestamp" .

:hasDepthScore a owl:DatatypeProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range xsd:integer ;
    rdfs:label "Authority Depth Score" .

:hasPracticeArea a owl:ObjectProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range :PracticeArea .

:supportedBy a owl:ObjectProperty ;
    rdfs:domain :PillarPage ;
    rdfs:range :ClusterArticle .

:measuredBy a owl:ObjectProperty ;
    rdfs:domain :PillarPage ;
    rdfs:range :AuditMetric .

:operatesIn a owl:ObjectProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range :Jurisdiction .

#################################################################
#    2. Top-Level Classes
#################################################################

:LegalServiceProvider a owl:Class ; rdfs:label "Legal Service Provider" .
:PracticeArea a owl:Class ; rdfs:label "Practice Area" .
:PillarPage a owl:Class ; rdfs:label "Pillar Page" .
:ClusterArticle a owl:Class ; rdfs:label "Cluster Article" .
:AuditMetric a owl:Class ; rdfs:label "Audit Metric" .
:Jurisdiction a owl:Class ; rdfs:label "Jurisdiction" .
:AuthorityScore a owl:Class ; rdfs:subClassOf :AuditMetric .

#################################################################
#    3. Accident Cluster Hierarchy (Section 6.1 & 6.2)
#################################################################

:MotorVehicleAccident a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Motor Vehicle Accident" .

:CarAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Car Accident" .

:TruckAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Truck Accident" .

:MotorcycleAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Motorcycle Accident" .

:EighteenWheelerAccident a owl:Class ; 
    rdfs:subClassOf :TruckAccident ; 
    rdfs:label "18-Wheeler Accident" .

#################################################################
#    4. Statutory Layer (Section 6.4)
#################################################################

:TexasStatutoryAnchor a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Texas Statutory Compliance" .

:CPRC_33_ProportionateResponsibility a owl:Class ; 
    rdfs:subClassOf :TexasStatutoryAnchor ; 
    rdfs:label "Chapter 33 Proportionate Responsibility" .

#################################################################
#    5. v2.0 Compliance Instance (Verification Entry)
#################################################################

:SampleFirm_Dallas a :LegalServiceProvider ;
    :hasDepthScore 5 ;
    :hasPracticeArea :CarAccident ;
    :operatesIn :DallasCounty ;
    :lastValidated "2026-03-06T13:00:00Z"^^xsd:dateTime .

:DallasCounty a :Jurisdiction ; rdfs:label "Dallas County, TX" .
