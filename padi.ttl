@prefix : <https://padi.authority/v1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://padi.authority/v1/> rdf:type owl:Ontology ;
    rdfs:label "PADI v1.0 Master Taxonomy" .

### --- 6.1 Accident Cluster Hierarchy ---

:MotorVehicleAccident a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Motor Vehicle Accident" .

:CarAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Car Accident" .

:TruckAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Truck Accident" .

:MotorcycleAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Motorcycle Accident" .

### --- 6.2 Granular Subtopics (Verified Labels) ---

:RearEndCollision a owl:Class ; 
    rdfs:subClassOf :CarAccident ; 
    rdfs:label "Rear-End Collision" .

:TBoneAccident a owl:Class ; 
    rdfs:subClassOf :CarAccident ; 
    rdfs:label "T-Bone Accident" .

:UberLyftAccident a owl:Class ; 
    rdfs:subClassOf :CarAccident ; 
    rdfs:label "Uber and Lyft Accident" .

:DrunkDrivingAccident a owl:Class ; 
    rdfs:subClassOf :CarAccident ; 
    rdfs:label "Drunk Driving Accident" .

:EighteenWheelerAccident a owl:Class ; 
    rdfs:subClassOf :TruckAccident ; 
    rdfs:label "18-Wheeler Accident" .

:JackknifeAccident a owl:Class ; 
    rdfs:subClassOf :TruckAccident ; 
    rdfs:label "Jackknife Accident" .

:UnderrideAccident a owl:Class ; 
    rdfs:subClassOf :TruckAccident ; 
    rdfs:label "Underride Accident" .

:FMCSA_Compliance a owl:Class ; 
    rdfs:subClassOf :TruckAccident ; 
    rdfs:label "FMCSA Compliance" .

### --- 6.4 Statutory Layer (Dallas Jurisdictional Anchor) ---

:TexasStatutoryAnchor a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Texas Statutory Compliance" .

:CPRC_33_ProportionateResponsibility a owl:Class ; 
    rdfs:subClassOf :TexasStatutoryAnchor ; 
    rdfs:label "Chapter 33 Proportionate Responsibility" .

:CPRC_16_Limitations a owl:Class ; 
    rdfs:subClassOf :TexasStatutoryAnchor ; 
    rdfs:label "Statute of Limitations" .

:CPRC_41_ExemplaryDamages a owl:Class ; 
    rdfs:subClassOf :TexasStatutoryAnchor ; 
    rdfs:label "Exemplary Damages" .
