@prefix padi: <https://padi.authority/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix schema: <https://schema.org/> .

<https://padi.authority/ontology#> a owl:Ontology ;
    rdfs:label "PADI Technical Standard Ontology v1.0" ;
    dc:creator "Samuel Muriithi, B.S. Information Science" ;
    dc:description "A specialized application of Library Science classification models for legal authority architecture." ;
    schema:academicProvenance <http://www.wikidata.org/entity/Q163205> ; # Information Science
    schema:specialization <http://www.wikidata.org/entity/Q199657> ; # Library Science
    rdfs:comment "This ontology establishes the formal Knowledge Organization System (KOS) for practice-area depth." .

#################################################################
#    Classes
#################################################################

padi:LegalServiceProvider a owl:Class ;
    rdfs:label "Legal Service Provider" ;
    rdfs:comment "An entity providing regulated legal services within a jurisdiction." .

padi:PracticeArea a owl:Class ;
    rdfs:label "Practice Area" ;
    rdfs:comment "A specific domain of legal expertise (e.g., Personal Injury)." .

padi:CaseSubtype a owl:Class ;
    rdfs:label "Case Subtype" ;
    rdfs:comment "A specialized niche within a practice area (e.g., Trucking Accidents)." .

padi:LegalMechanism a owl:Class ;
    rdfs:label "Legal Mechanism" ;
    rdfs:comment "The doctrinal elements required to prove liability (e.g., Duty, Breach, Causation, Damages)." .

padi:Jurisdiction a owl:Class ;
    rdfs:label "Jurisdiction" ;
    rdfs:comment "The geographic or legal boundary where authority is exercised." .

#################################################################
#    Properties
#################################################################

padi:hasPracticeArea a owl:ObjectProperty ;
    rdfs:domain padi:LegalServiceProvider ;
    rdfs:range padi:PracticeArea .

padi:hasSubtype a owl:ObjectProperty ;
    rdfs:domain padi:PracticeArea ;
    rdfs:range padi:CaseSubtype .

padi:hasMechanism a owl:ObjectProperty ;
    rdfs:domain padi:CaseSubtype ;
    rdfs:range padi:LegalMechanism .

padi:governedBy a owl:ObjectProperty ;
    rdfs:domain padi:CaseSubtype ;
    rdfs:range padi:Jurisdiction .

padi:hasDepthScore a owl:DatatypeProperty ;
    rdfs:domain padi:LegalServiceProvider ;
    rdfs:range xsd:integer .

#################################################################
#    Individuals (Dallas PI Market Context)
#################################################################

padi:PersonalInjury a padi:PracticeArea ;
    rdfs:label "Personal Injury" .

padi:TruckingAccidents a padi:CaseSubtype ;
    rdfs:label "Commercial Trucking Accidents" ;
    padi:hasMechanism padi:Causation .
