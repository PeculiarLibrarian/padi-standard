@prefix : <https://padi.authority/v1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix schema: <https://schema.org/> .
@base <https://padi.authority/v1/> .

<https://padi.authority/v1/> a owl:Ontology ;
    rdfs:label "PADI Technical Standard Ontology v1.0" ;
    dc:creator "Samuel Muriithi, B.S. Information Science" ;
    dc:description "A specialized application of Library Science classification models for legal authority architecture." ;
    schema:academicProvenance <http://www.wikidata.org/entity/Q163205> ;
    schema:specialization <http://www.wikidata.org/entity/Q199657> .

#################################################################
#    1. Core System & Content Classes
#################################################################

:LegalServiceProvider a owl:Class ;
    rdfs:label "Legal Service Provider" .

:Jurisdiction a owl:Class ;
    rdfs:label "Jurisdiction" ;
    rdfs:comment "Geographic or legal boundary (e.g., Dallas County)." .

:PracticeArea a owl:Class ;
    rdfs:label "Practice Area" .

:CaseSubtype a owl:Class ;
    rdfs:label "Case Subtype" .

:ContentNode a owl:Class ;
    rdfs:label "Content Node" ;
    rdfs:comment "Abstract class for all authority-building digital assets." .

:PillarPage a owl:Class ;
    rdfs:subClassOf :ContentNode ;
    rdfs:label "Authority Pillar Page" .

:ClusterArticle a owl:Class ;
    rdfs:subClassOf :ContentNode ;
    rdfs:label "Cluster Article" .

#################################################################
#    2. Authority Measurement & Audit Classes
#################################################################

:AuditMetric a owl:Class ;
    rdfs:label "Audit Metric" .

:AuthorityScore a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Topical Authority Score" .

:AuthorityGap a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Structural Authority Gap" .

:VerifiedAuthority a owl:Class ;
    owl:equivalentClass [ rdf:type owl:Restriction ;
                          owl:onProperty :hasDepthScore ;
                          owl:minQualifiedCardinality "3"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:integer
                        ] ;
    rdfs:label "1003 Verified Authority" .

#################################################################
#    3. Object Properties (Entity Relationships)
#################################################################

:operatesIn a owl:ObjectProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range :Jurisdiction .

:hasPillar a owl:ObjectProperty ;
    rdfs:domain :CaseSubtype ;
    rdfs:range :PillarPage .

:supportedBy a owl:ObjectProperty ;
    rdfs:domain :PillarPage ;
    rdfs:range :ClusterArticle .

:measuredBy a owl:ObjectProperty ;
    rdfs:domain :ContentNode ;
    rdfs:range :AuthorityScore .

:exhibitsGap a owl:ObjectProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range :AuthorityGap .

#################################################################
#    4. Datatype Properties
#################################################################

:hasDepthScore a owl:DatatypeProperty ;
    rdfs:domain :LegalServiceProvider ;
    rdfs:range xsd:integer .

:gapMagnitude a owl:DatatypeProperty ;
    rdfs:domain :AuthorityGap ;
    rdfs:range xsd:decimal .

#################################################################
#    5. Individuals (Sample Context)
#################################################################

:DallasJurisdiction a :Jurisdiction ;
    rdfs:label "Dallas, TX" .

:TruckingAccidents a :CaseSubtype ;
    :hasPillar :DallasTruckingPillar .
