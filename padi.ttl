#################################################################
#    6. PADI Master Taxonomy: Personal Injury (Dallas Market)
#    Structural Hierarchy for Topical Coverage (TC) Calculation
#################################################################

### --- 6.1 Accident Cluster Hierarchy ---

:MotorVehicleAccident a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Motor Vehicle Accident" .

:CarAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Car Accident" .

:TruckAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Truck Accident" .

:MotorcycleAccident a owl:Class ;
    rdfs:subClassOf :MotorVehicleAccident ;
    rdfs:label "Motorcycle Accident" .

### --- 6.2 Granular Subtopics (1003 Cardinality Targets) ---

# Car Accident Subtopics
:RearEndCollision a owl:Class ; rdfs:subClassOf :CarAccident .
:TBoneAccident a owl:Class ; rdfs:subClassOf :CarAccident .
:UberLyftAccident a owl:Class ; rdfs:subClassOf :CarAccident .
:DrunkDrivingAccident a owl:Class ; rdfs:subClassOf :CarAccident .

# Truck Accident Subtopics (High-Gravity Nodes)
:EighteenWheelerAccident a owl:Class ; rdfs:subClassOf :TruckAccident .
:JackknifeAccident a owl:Class ; rdfs:subClassOf :TruckAccident .
:UnderrideAccident a owl:Class ; rdfs:subClassOf :TruckAccident .
:FMCSA_Compliance a owl:Class ; rdfs:subClassOf :TruckAccident .

### --- 6.3 Specialized Practice Areas ---

:PremisesLiability a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Premises Liability (Slip and Fall)" .

:MedicalMalpractice a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Medical Malpractice" .

:WorkplaceInjury a owl:Class ;
    rdfs:subClassOf :PracticeArea ;
    rdfs:label "Workplace & Industrial Injury" .

### --- 6.4 Statutory & Procedural Layer (The Dallas Anchor) ---

:TexasStatutoryAnchor a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Texas Statutory Compliance Node" .

:CPRC_33_ProportionateResponsibility a owl:Class ; rdfs:subClassOf :TexasStatutoryAnchor .
:CPRC_16_Limitations a owl:Class ; rdfs:subClassOf :TexasStatutoryAnchor .
:CPRC_41_ExemplaryDamages a owl:Class ; rdfs:subClassOf :TexasStatutoryAnchor .

:LegalProcessNode a owl:Class ;
    rdfs:subClassOf :AuditMetric ;
    rdfs:label "Legal Process & Procedural Node" .

:DiscoveryProcess a owl:Class ; rdfs:subClassOf :LegalProcessNode .
:Dallas_ADR_Mediation a owl:Class ; rdfs:subClassOf :LegalProcessNode .
